# Copy to .env (gitignored) and fill in. Shape only — never commit real values.
# The app and the db:migrate/seed scripts load this .env automatically at startup
# (Node's built-in env-file support). Real environment variables take precedence.

PORT=3000

# Connect as a NON-superuser role so Postgres row-level security is actually
# enforced (a superuser bypasses RLS). See the README for the one-time setup.
DATABASE_URL=postgres://app_user:app_pass@localhost:5432/peers_restaurants

# Payments: leave unset to use the offline fake provider (recommended for local
# dev). Set the Moyasar secret key to use the real gateway. UNVERIFIED until
# go-live — see the payments module.
# MOYASAR_SECRET_KEY=sk_test_xxx
